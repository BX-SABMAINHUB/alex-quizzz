{
  "version": 2,
  "builds": [
    {
      "src": "classquiz/main.py",          // ← Aquí usa "classquiz/main.py" (o el archivo real donde está 'app')
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",                // Para el frontend SvelteKit si está en frontend/
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/build" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "classquiz/main.py"          // Ruta para la API (ajusta si tus endpoints son /api/...)
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"               // Sirve el frontend estático para todo lo demás
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
